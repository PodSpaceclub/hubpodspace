# ==============================================
# PodSpace Club — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha os valores

# ----------------------------------------------
# BANCO DE DADOS
# ----------------------------------------------
# MySQL (produção — Hostinger ou outro managed hosting):
DATABASE_URL="mysql://usuario:senha@localhost:3306/nome_do_banco"
# SQLite (desenvolvimento local):
# DATABASE_URL="file:./prisma/dev.db"

# ----------------------------------------------
# AUTENTICAÇÃO (NextAuth.js)
# ----------------------------------------------
# Gere um secret seguro: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-aqui"
# URL base da aplicação (sem barra no final)
NEXTAUTH_URL="https://podspaceclub.com.br"

# ----------------------------------------------
# STRIPE — Pagamentos
# ----------------------------------------------
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ----------------------------------------------
# APLICAÇÃO
# ----------------------------------------------
NEXT_PUBLIC_APP_URL="https://podspaceclub.com.br"
