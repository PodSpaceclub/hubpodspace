# ==============================================
# PodSpace Club — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha os valores

# ----------------------------------------------
# BANCO DE DADOS
# ----------------------------------------------
# SQLite (desenvolvimento e VPS com servidor único):
DATABASE_URL="file:./dev.db"
# PostgreSQL (produção distribuída):
# DATABASE_URL="postgresql://usuario:senha@host:5432/podspace"

# ----------------------------------------------
# AUTENTICAÇÃO (NextAuth.js)
# ----------------------------------------------
# Gere um secret seguro: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-aqui"
# URL base da aplicação (sem barra no final)
NEXTAUTH_URL="https://podspaceclub.com.br"

# ----------------------------------------------
# STRIPE — Pagamentos
# ----------------------------------------------
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ----------------------------------------------
# APLICAÇÃO
# ----------------------------------------------
NEXT_PUBLIC_APP_URL="https://podspaceclub.com.br"
